		<script type="text/javascript">
			$(document).ready(function () {
				//I'm on fire. One-liner search lol
				// body...
				$('#skillsearch').keyup(function () { $(".item-skills").each(function (i, el) { ~($(el).text().toLowerCase().indexOf($("#skillsearch").val())) ? $(el).show() : $(el).hide() }) })
			});

		</script>

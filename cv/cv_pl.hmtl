								<div class="item-skills" data-percent="0.60">Play Framework</div>
								<div class="item-skills" data-percent="0.60">Dart</div>
								<div class="item-skills" data-percent="0.60">Meteor.js</div>

								<div class="item-skills" data-percent="0.50">Akka</div>

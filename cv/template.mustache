<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<meta name="google-translate-customization" content="92a3cbb1325a21fc-104c316a883fa5c4-g2f46984ae24d3013-b">
	</meta>
	<title>Krzysztof Wende</title>
	<link href="css/bootstrap.min.css" rel="stylesheet">
	<link href="css/font-awesome.css" rel="stylesheet">
	<link href="css/main.css" rel="stylesheet">
	<!--[if lt IE 9]>
		<script src="js/html5shiv.js"></script>
		<script src="js/respond.min.js"></script>
		<![endif]-->
</head>

<body>
	<script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
	<div class="container">
		<div class="row">
			<div class="col-xs-12">
				<div id="photo-header" class="text-center">
					<!-- PHOTO (AVATAR) -->
					<div id="photo">
						<img src="https://media.licdn.com/dms/image/C4D03AQFohGdKdQ1nZg/profile-displayphoto-shrink_200_200/0?e=1545264000&v=beta&t=Oe6tjdYGD2Jg-ejsG0JI_oH5evRX3DwUJLhpD5_6hEY"
						 alt="avatar">
					</div>
					<div id="text-header">
						<h1>{{ hello }},<br> {{ myNameIs }} <span>Krzysztof</span><sup></sup> {{ thisIsMyResume }}</h1>
					</div>
				</div>
			</div>
		</div>
		<div class="row">
			<div class="col-xs-12 col-sm-7">
				<!-- About Me -->
				<div class="box">
					<h2>{{ aboutMeHeadline }}</h2>
					<ul id="education" class="clearfix">
						{{ #badges }}
						<li>
							<div id="mini-photo" class="pull-left">
								<img src="{{ logo }}" style=" {{ logoStyle }}"
								 alt="avatar">
							</div>
							<div class="description pull-right" style="width:85%">
								<h3>{{ title }}</h3>
								<p> {{{ description }}} </p>
							</div>
						</li>
						{{ /badges }}
					</ul>

				</div>
				<!-- Work history -->
				<div class="box">
					<h2> {{ workHistoryHeadline }} </h2>
					<ul id="education" class="clearfix">
						{{ #workHistory }}
							<li>
							<div class="year pull-left"> {{ time }}</div>
							<div class="description pull-right">
								<h3>{{ title }} </h3>
								<p> {{{ description }}} </p>
							</div>
						</li>
						{{ /workHistory }}

					</ul>
				</div>

			</div>
			<div class="col-xs-12 col-sm-5">
				<!-- CONTACT -->
				<div class="box clearfix">
					<h2> {{ contactHeadline }} </h2>
					{{ #contact }}
					<div class="contact-item">
						<div class="icon pull-left text-center"><span class="fa {{ fa }} fa-fw"></span></div>
						<div class="title only pull-right">{{ value }}</div>
						<a class="description pull-right" href="{{ link }}">{{ link }}</a>
					</div>
					{{ /contact }}
				</div>
				<!-- EXPERIENCES -->
				<div class="box">
					<h2> {{ experienceHeadline }} </h2>
					{{ #experiences }}
						<div class="job clearfix">
							<div class="col-xs-4">
								<div class="where">{{ where }}</div>
								<div class="year">{{ year }}</div>
							</div>
							<div class="col-xs-8">
								<div class="profession">{{ title }}</div>
								<div class="description"> {{description }}</div>
							</div>
						</div>
					{{ /experiences }}
				</div>
				<!-- SKILLS -->
				<div class="box">
					<h2>{{ skillsHeadline }} &nbsp&nbsp&nbsp&nbsp&nbsp<input id="skillsearch"></h2>
					<div class="skills">
						{{ #skills }}
							<div class="item-skills" data-percent="{{ proficiency }} "> {{ name }} </div>
						{{ /skills}}
						<div class="skills-legend clearfix">
							<div class="legend-left legend"> {{ proficiencies.beginner }} </div>
							<div class="legend-left legend"><span> {{ proficiencies.proficient }}</span></div>
							<div class="legend-right legend"><span> {{ proficiencies.expert }} </span></div>
							<div class="legend-right legend"> {{ proficiencies.master }} </div>
						</div>
					</div>
				</div>

				<!-- LANGUAGES -->
				<div class="box">
					<h2> {{ languagesHeadline }} </h2>

					<div id="language-skills">
						{{ #languages }}
							<div class="skill">{{ language }} <div class="icons pull-right">
									<div style="width: {{ proficiency }};" class="icons-red"></div>
								</div>
							</div>
						{{ /languages }}
					</div>
				</div>

				<!-- TESTIMONIALS -->
				<div class="box">
					<h2>{{ testimonialsHeadline }} </h2>
					<ul id="education" class="clearfix">
						{{ #testimonials }}
							<li>
								<div id="mini-photo" class="pull-left">
									<img src=" {{ face }}" alt="avatar">
								</div>
								<div class="description pull-right" style="width:80%">
									<h3> {{ who }} </h3>
									<p> "{{ text }}" </p>
								</div>
							</li>
						{{ /testimonials }}
					</ul>

				</div>

				<!-- TALKS -->
				<div class="box">
					<h2> {{ talksHeadline }} </h2>
					{{ #talks }}
						<div class="job clearfix">
							<div class="col-xs-4">
								<div class="where">{{ where }}</div>
								<div class="year">{{ year }}</div>
							</div>
							<div class="col-xs-8">
								<div class="profession">{{ title }}</div>
								<div class="description"> <a href="{{ link }}"> {{ link }} </a> </div>
							</div>
						</div>
					{{ /talks }}
				</div>

				<!-- TALKS -->
				<div class="box">
					<h2> {{ interviewsHeadline }} </h2>
					{{ #interviews }}
						<div class="job clearfix">
							<div class="col-xs-4">
								<div class="where">{{ where }}</div>
								<div class="year">{{ year }}</div>
							</div>
							<div class="col-xs-8">
								<div class="profession">{{ title }}</div>
								<div class="description"> <a href="{{ link }}"> {{ link }} </a> </div>
							</div>
						</div>
					{{ /interviews }}
				</div>

				<!-- HOBBIES -->
				<div class="box">
					<h2> {{ hobbiesHeadline }} </h2>
					{{ #hobbies }}
					<div class="hobby">{{ . }}</div>
					{{ /hobbies }}

				</div>

			</div>
		</div>
		<!-- JQUERY -->
		<script src="js/jquery.min.js"></script>
		<!-- BOOTSTRAP -->
		<script src="js/bootstrap.min.js"></script>
		<!-- SCRIPTS -->
		<script src="js/scripts.js"></script>
		<script type="text/javascript">
			$(document).ready(function () {
				//I'm on fire. One-liner search lol
				// body...
				$('#skillsearch').keyup(function () {
					$(".item-skills").each(function (i, el) {
						~($(el)
							.text()
							.toLowerCase()
							.indexOf($("#skillsearch")
							.val())
						 ) ? $(el).show() : $(el).hide()
					})
				})
			});

		</script>
		<script>
			(function (i, s, o, g, r, a, m) {
				i['GoogleAnalyticsObject'] = r; i[r] = i[r] || function () {
					(i[r].q = i[r].q || []).push(arguments)
				}, i[r].l = 1 * new Date(); a = s.createElement(o),
					m = s.getElementsByTagName(o)[0]; a.async = 1; a.src = g; m.parentNode.insertBefore(a, m)
			})(window, document, 'script', '//www.google-analytics.com/analytics.js', 'ga');

			ga('create', 'UA-56241713-2', 'auto');
			ga('send', 'pageview');

		</script>
</body>

</html>